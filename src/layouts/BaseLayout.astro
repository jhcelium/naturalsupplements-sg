---
import Seo from "../components/Seo.astro";
import site from "../../data/site.json";
import { canonicalUrl, siteOrigin } from "../lib/canonical";

interface Props {
  title?: string;
  fullTitle?: string;
  description?: string;
  path?: string;
  /** Absolute path to Open Graph image, e.g. /logo.png */
  image?: string;
}
const { title, fullTitle, description, path, image } = Astro.props;

const orgJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": site.siteName,
  "url": canonicalUrl("/"),
  "logo": `${siteOrigin()}/logo.png`,
  "description": "An educational resource about natural supplement labels, clean label terminology, and ingredient transparency for Singapore consumers.",
  "inLanguage": "en-SG",
  "sameAs": [site.officialSite],
  "knowsAbout": [
    "natural supplements",
    "clean label supplements",
    "herbal supplements Singapore",
    "supplement label transparency",
    "organic vs natural supplements",
    "supplement ingredient disclosure",
  ],
  "areaServed": { "@type": "Country", "name": "Singapore" },
});
---
<!DOCTYPE html>
<html lang="en-SG">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/logo.png" />
    <meta name="theme-color" content="#1a5ca0" />
    <Seo title={title} fullTitle={fullTitle} description={description} path={path} image={image} />
    <script type="application/ld+json" set:html={orgJsonLd}></script>
    <style>
      /* ── Variables ───────────────────────────────────── */
      :root {
        --font: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        --text:           #1a1a1a;
        --text-secondary: #444444;
        --text-muted:     #767676;
        --border:         #d0d0d0;
        --border-light:   #e8e8e8;
        --accent:         #1a5ca0;
        --bg:             #ffffff;
        --bg-subtle:      #f7f7f7;
        --max-w:          960px;
      }

      /* ── Reset ───────────────────────────────────────── */
      *, *::before, *::after { box-sizing: border-box; }

      /* ── Base ────────────────────────────────────────── */
      body {
        margin: 0;
        background: var(--bg);
        color: var(--text);
        font-family: var(--font);
        font-size: 16px;
        line-height: 1.75;
        -webkit-font-smoothing: antialiased;
      }

      /* ── Layout ──────────────────────────────────────── */
      header {
        border-bottom: 1px solid var(--border-light);
      }
      .header-inner {
        max-width: var(--max-w);
        margin: 0 auto;
        padding: 14px 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      main {
        max-width: var(--max-w);
        margin: 0 auto;
        padding: 44px 24px 72px;
      }
      footer {
        border-top: 1px solid var(--border-light);
        margin-top: 0;
      }
      .footer-inner {
        max-width: var(--max-w);
        margin: 0 auto;
        padding: 20px 24px;
        font-size: 13px;
        color: var(--text-muted);
        display: flex;
        flex-wrap: wrap;
        gap: 4px 24px;
        align-items: baseline;
      }

      /* ── Nav ─────────────────────────────────────────── */
      nav {
        display: flex;
        align-items: center;
        gap: 20px;
      }
      nav a {
        font-size: 12px;
        font-weight: 500;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--text-secondary);
        text-decoration: none;
      }
      nav a:hover {
        color: var(--text);
      }

      /* ── Logo ────────────────────────────────────────── */
      .header-logo {
        display: flex;
        align-items: center;
        flex-shrink: 0;
      }
      .header-logo img {
        height: 30px;
        width: auto;
        display: block;
      }

      /* ── Links ───────────────────────────────────────── */
      a {
        color: var(--accent);
        text-decoration: underline;
        text-decoration-color: transparent;
        text-underline-offset: 3px;
      }
      a:hover {
        text-decoration-color: currentColor;
      }

      /* ── Headings ────────────────────────────────────── */
      h1 {
        font-size: 2rem;
        font-weight: 700;
        line-height: 1.2;
        letter-spacing: -0.02em;
        margin: 0 0 20px;
        color: var(--text);
      }
      h2 {
        font-size: 1.1875rem;
        font-weight: 600;
        line-height: 1.3;
        margin: 52px 0 14px;
        padding-top: 20px;
        border-top: 1px solid var(--border-light);
        color: var(--text);
      }
      h3 {
        font-size: 1rem;
        font-weight: 600;
        margin: 28px 0 8px;
        color: var(--text);
      }

      /* ── Body text ───────────────────────────────────── */
      p {
        margin: 0 0 18px;
        color: var(--text-secondary);
      }
      strong {
        color: var(--text);
        font-weight: 600;
      }
      em {
        color: var(--text-secondary);
      }

      /* ── Lists ───────────────────────────────────────── */
      ul, ol {
        margin: 0 0 18px;
        padding-left: 1.4em;
      }
      li {
        margin-bottom: 6px;
        color: var(--text-secondary);
      }

      /* ── Disclaimer ──────────────────────────────────── */
      .disclaimer {
        border-top: 1px solid var(--border);
        border-bottom: 1px solid var(--border);
        padding: 10px 0;
        font-size: 13px;
        color: var(--text-muted);
        font-style: italic;
        margin: 0 0 36px;
      }

      /* ── Definition block ────────────────────────────── */
      /* Use <blockquote> in markdown, or class="definition" */
      blockquote,
      .definition {
        margin: 28px 0;
        padding: 12px 16px;
        border-left: 2px solid var(--border);
        background: var(--bg-subtle);
        font-size: 0.9375rem;
        color: var(--text-secondary);
      }
      blockquote p,
      .definition p {
        margin: 0;
      }

      /* ── Key takeaway ────────────────────────────────── */
      .key-takeaway {
        margin: 36px 0;
        padding: 14px 16px;
        border: 1px solid var(--border);
        border-left-width: 3px;
        background: var(--bg-subtle);
        font-size: 0.9375rem;
      }
      .key-takeaway p {
        margin: 0;
        color: var(--text);
      }

      /* ── Cross reference / hub link ──────────────────── */
      .hub-link-block,
      .cross-ref {
        margin: 36px 0 0;
        padding: 10px 14px;
        border-left: 2px solid var(--border-light);
        font-size: 14px;
      }
      .hub-link-block p,
      .cross-ref p {
        margin: 0;
        color: var(--text-muted);
      }

      /* ── Checklist ───────────────────────────────────── */
      .checklist {
        list-style: none;
        padding: 0;
        margin: 0 0 18px;
      }
      .checklist li {
        padding: 8px 0 8px 22px;
        position: relative;
        border-bottom: 1px solid var(--border-light);
        font-size: 0.9375rem;
        color: var(--text-secondary);
        margin: 0;
      }
      .checklist li:first-child {
        border-top: 1px solid var(--border-light);
      }
      .checklist li::before {
        content: "–";
        position: absolute;
        left: 0;
        color: var(--text-muted);
      }

      /* ── Official link button ────────────────────────── */
      .official-link {
        display: inline-block;
        border: 1px solid var(--border);
        padding: 8px 16px;
        font-size: 14px;
        font-weight: 500;
        color: var(--text);
        text-decoration: none;
        letter-spacing: 0.01em;
      }
      .official-link:hover {
        background: var(--bg-subtle);
        text-decoration-color: transparent;
      }

      /* ── Figures / images ────────────────────────────── */
      .guide-figure {
        margin: 36px 0;
      }
      .guide-img {
        width: 100%;
        height: auto;
        display: block;
        border: 1px solid var(--border-light);
      }
      .guide-figure figcaption {
        font-size: 12px;
        color: var(--text-muted);
        margin-top: 6px;
        font-style: italic;
      }

      /* ── Breadcrumb (visible; pairs with BreadcrumbList JSON-LD) ── */
      .breadcrumb {
        margin: 0 0 20px;
        padding-bottom: 12px;
        border-bottom: 1px solid var(--border-light);
      }
      .breadcrumb__list {
        display: flex;
        flex-wrap: wrap;
        align-items: baseline;
        gap: 0 4px;
        margin: 0;
        padding: 0;
        list-style: none;
        font-size: 12px;
        color: var(--text-muted);
        letter-spacing: 0.02em;
      }
      .breadcrumb__item {
        display: inline-flex;
        align-items: baseline;
        margin: 0;
      }
      .breadcrumb__item:not(:last-child)::after {
        content: "/";
        margin-left: 4px;
        color: var(--border);
        font-weight: 400;
        text-decoration: none;
        pointer-events: none;
      }
      .breadcrumb__item a {
        color: var(--text-muted);
        text-decoration: none;
      }
      .breadcrumb__item a:hover {
        color: var(--text);
        text-decoration: underline;
        text-decoration-color: currentColor;
      }
      .breadcrumb__current {
        color: var(--text-secondary);
        font-weight: 500;
      }

      /* ── Responsive ──────────────────────────────────── */
      @media (max-width: 600px) {
        h1 { font-size: 1.625rem; }
        h2 { font-size: 1.0625rem; margin-top: 40px; }
        main { padding: 32px 16px 56px; }
        .header-inner { padding: 12px 16px; }
        .footer-inner { padding: 16px; }
      }
    </style>
  </head>
  <body>
    <header>
      <div class="header-inner">
        <nav>
          <a href="/">Home</a>
          <a href="/about">About</a>
          <a href="/faq">FAQ</a>
        </nav>
        <a href={site.officialSite} target="_blank" rel="noopener noreferrer" class="header-logo">
          <img src="/logo.png" alt="supplement.neoi.jp" />
        </a>
      </div>
    </header>

    <main>
      <slot name="breadcrumb" />
      <slot />
    </main>

    <footer>
      <div class="footer-inner">
        <span>{site.siteName}</span>
        <span>Educational content only. Not medical or treatment advice.</span>
        <a href={site.officialSite} target="_blank" rel="noopener noreferrer">Official Neoi Site</a>
      </div>
    </footer>
  </body>
</html>
