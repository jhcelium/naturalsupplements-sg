---
import BaseLayout from "../layouts/BaseLayout.astro";
import { loadMarkdown } from "../lib/content";
import site from "../../data/site.json";

const home = loadMarkdown("home.md");

const websiteJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": site.siteName,
  "url": `https://${site.domain}/`,
  "inLanguage": "en-SG",
  "description": home.frontmatter.description,
  "about": {
    "@type": "Thing",
    "name": "Natural supplement label transparency in Singapore",
    "description": "Educational content about what 'natural', 'clean label', and 'organic' mean on supplement packaging sold in Singapore.",
  },
  "publisher": {
    "@type": "Organization",
    "name": site.siteName,
    "url": `https://${site.domain}/`,
    "logo": `https://${site.domain}/logo.png`,
  },
  "speakable": {
    "@type": "SpeakableSpecification",
    "cssSelector": ["h1", "main > p:first-of-type"],
  },
});
---
<BaseLayout title={home.frontmatter.title} description={home.frontmatter.description} path="/">
  <h1>Natural Supplements in Singapore: What &#34;Natural&#34; Actually Means</h1>

  <p>A calm guide to <strong>natural supplements in Singapore</strong>: what &#34;natural&#34; and <strong>clean label</strong> terms mean on supplement packaging, how ingredient transparency works, and how to read a label more carefully.</p>

  <div class="disclaimer">
    This site provides general educational information only. It is not medical advice, diagnosis, or treatment recommendation. Always speak with a qualified clinician about your own situation.
  </div>

  <figure class="guide-figure">
    <img
      src="/home-guide.png"
      alt="Visual guide: Natural Supplements in Singapore — what 'natural' means, ingredient transparency checklist, clean label vs natural, Singapore context, Japan perspective"
      class="guide-img"
      width="960"
      height="540"
      loading="eager"
      fetchpriority="high"
      decoding="sync"
    />
    <figcaption>Overview of key topics covered on this page.</figcaption>
  </figure>

  <article set:html={home.html} />

  <div class="hub-link-block">
    <p>For a broader look at the Singapore supplement market, see the <a href="https://supplementsingapore.neoi.jp">Supplements Singapore guide</a>.</p>
  </div>

  <p style="margin-top: 32px;">
    <a href={site.officialSite} target="_blank" rel="noopener" class="official-link">
      Visit Official Neoi Supplement Site →
    </a>
  </p>

  <script type="application/ld+json" set:html={websiteJsonLd}></script>
</BaseLayout>
