---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BreadcrumbNav from "../../components/BreadcrumbNav.astro";
import { loadArticle, listArticleIds } from "../../lib/content";
import { canonicalUrl, siteOrigin } from "../../lib/canonical";
import site from "../../../data/site.json";

export async function getStaticPaths() {
  const ids = listArticleIds();
  return ids.map((id) => ({ params: { id } }));
}

const { id } = Astro.params;
const article = loadArticle(id!);

const today = new Date().toISOString().split("T")[0];
const publishDate = article.frontmatter.datePublished ?? "2024-01-01";
const modifyDate  = article.frontmatter.dateModified  ?? today;

const homeUrl = canonicalUrl("/");
const articleUrl = canonicalUrl(`/articles/${id}`);

const articleJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": article.frontmatter.title,
  "description": article.frontmatter.description ?? "",
  "url": articleUrl,
  "datePublished": publishDate,
  "dateModified": modifyDate,
  "inLanguage": "en-SG",
  "author": {
    "@type": "Organization",
    "name": site.siteName,
    "url": homeUrl,
  },
  "publisher": {
    "@type": "Organization",
    "name": site.siteName,
    "logo": {
      "@type": "ImageObject",
      "url": `${siteOrigin()}/logo.png`,
    },
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": articleUrl,
  },
  "isPartOf": {
    "@type": "WebSite",
    "name": site.siteName,
    "url": homeUrl,
  },
  "speakable": {
    "@type": "SpeakableSpecification",
    "cssSelector": ["h1", "article > p:first-of-type"],
  },
});

const breadcrumbJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": homeUrl,
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": article.frontmatter.title,
      "item": articleUrl,
    },
  ],
});
---
<BaseLayout
  title={article.frontmatter.title}
  description={article.frontmatter.description}
  path={`/articles/${id}`}
>
  <BreadcrumbNav
    slot="breadcrumb"
    items={[{ name: "Home", href: "/" }, { name: article.frontmatter.title }]}
  />
  <h1>{article.frontmatter.title}</h1>
  <article set:html={article.html} />
  <p style="margin-top:32px"><a href="/">← Back to home</a></p>
  <script type="application/ld+json" set:html={articleJsonLd}></script>
  <script type="application/ld+json" set:html={breadcrumbJsonLd}></script>
</BaseLayout>
