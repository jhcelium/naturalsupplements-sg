---
import BaseLayout from "../layouts/BaseLayout.astro";
import BreadcrumbNav from "../components/BreadcrumbNav.astro";
import { loadMarkdown } from "../lib/content";
import { canonicalUrl } from "../lib/canonical";
import site from "../../data/site.json";

const homeUrl = canonicalUrl("/");
const faqUrl = canonicalUrl("/faq");

const loaded = loadMarkdown("faq.md");
const { frontmatter, html } = loaded;
const faqItems = frontmatter.faq ?? [];

const today = new Date().toISOString().split("T")[0];

const breadcrumbJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": homeUrl },
    { "@type": "ListItem", "position": 2, "name": "FAQ", "item": faqUrl },
  ],
});

const faqJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "inLanguage": "en-SG",
  "dateModified": today,
  "speakable": {
    "@type": "SpeakableSpecification",
    "cssSelector": ["h1", "article p:first-of-type"],
  },
  "mainEntity": faqItems.map((item) => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a },
  })),
});
---
<BaseLayout title={frontmatter.title} description={frontmatter.description} path="/faq">
  <BreadcrumbNav
    slot="breadcrumb"
    items={[{ name: "Home", href: "/" }, { name: "FAQ" }]}
  />
  <h1>Natural Supplements Questions in Singapore</h1>

  <div class="disclaimer">
    General educational information only. Not medical advice. Always consult a qualified clinician for your own situation.
  </div>

  <article set:html={html} />

  <figure class="guide-figure">
    <img
      src="/faq-bioavailability.png"
      alt="Infographic: Understanding Bioavailability — how the body absorbs supplements, factors affecting absorption, high vs low bioavailability forms, and red flags to watch for on labels"
      class="guide-img"
      width="960"
      height="540"
      loading="lazy"
    />
    <figcaption>Bioavailability reference: absorption depends on chemical form, digestive health, and timing — not solely on whether an ingredient is labelled natural or synthetic.</figcaption>
  </figure>

  <div class="hub-link-block">
    <p>For a broader look at the Singapore supplement market, see the <a href="https://supplementsingapore.neoi.jp">Supplements Singapore guide</a>.</p>
  </div>

  <p style="margin-top: 32px;">
    <a href={site.officialSite} target="_blank" rel="noopener" class="official-link">
      Visit Official Neoi Supplement Site →
    </a>
  </p>

  <script type="application/ld+json" set:html={faqJsonLd}></script>
  <script type="application/ld+json" set:html={breadcrumbJsonLd}></script>
</BaseLayout>
