---
import BaseLayout from "../layouts/BaseLayout.astro";
import BreadcrumbNav from "../components/BreadcrumbNav.astro";
import { canonicalUrl } from "../lib/canonical";
import site from "../../data/site.json";

const fullTitle =
  "Natural Supplements Singapore | Definitions";
const description =
  "Plain-language definitions of natural supplement, clean label, and organic wording as used in Singapore-facing packaging and search — educational only, not certification or product guidance.";
const path = "/definitions";

const homeUrl = canonicalUrl("/");
const pageUrl = canonicalUrl(path);
const today = new Date().toISOString().split("T")[0];

/** Visible copy + DefinedTermSet entries stay aligned. */
const terms = [
  {
    name: "Natural (supplement labelling)",
    text: "Usually describes ingredient origin — plant, mineral, or animal-sourced — rather than fully synthetic manufacture. It is not one standard legal definition for all products in Singapore; read the full ingredient list rather than front-of-pack slogans alone.",
  },
  {
    name: "Clean label",
    text: "A marketing phrase for shorter, more readable ingredient lists and fewer unfamiliar additive names. It is not a single certified standard; brands define it differently, so the same words may not mean the same formulation.",
  },
  {
    name: "Organic (supplement context)",
    text: "Refers to how an ingredient was grown or produced, often with third-party agricultural certification. It is not interchangeable with “natural.” A label may show one term, both, or neither; check logos and supporting text for what is actually certified.",
  },
] as const;

const definedTermSetJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "DefinedTermSet",
  "name": "Supplement label vocabulary — Singapore context",
  "inLanguage": "en-SG",
  "url": pageUrl,
  "hasDefinedTerm": terms.map((t) => ({
    "@type": "DefinedTerm",
    "name": t.name,
    "description": t.text,
    "inDefinedTermSet": pageUrl,
  })),
});

const webPageJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": fullTitle,
  "description": description,
  "url": pageUrl,
  "inLanguage": "en-SG",
  "dateModified": today,
  "isPartOf": {
    "@type": "WebSite",
    "name": site.siteName,
    "url": homeUrl,
  },
});

const breadcrumbJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": homeUrl },
    { "@type": "ListItem", "position": 2, "name": "Definitions", "item": pageUrl },
  ],
});
---
<BaseLayout fullTitle={fullTitle} description={description} path={path}>
  <script slot="head" type="application/ld+json" set:html={definedTermSetJsonLd}></script>

  <BreadcrumbNav
    slot="breadcrumb"
    items={[{ name: "Home", href: "/" }, { name: "Definitions" }]}
  />

  <h1>Natural Supplements Singapore: Label Definitions</h1>

  <p>
    Short reference for how common words appear in <strong>natural supplements singapore</strong> search and on packaging.
    These notes explain <strong>clean label supplements</strong> language and <strong>natural vs organic supplements difference</strong> at a high level only — not medical advice, not endorsement, not certification claims.
  </p>

  <div class="disclaimer">
    Educational wording only. Not medical advice. For product-specific claims, check the label, manufacturer, certifier, or your clinician.
  </div>

  <section aria-label="Defined terms">
    {
      terms.map((t) => (
        <div class="def-term">
          <h2>{t.name}</h2>
          <p>{t.text}</p>
        </div>
      ))
    }
  </section>

  <div class="hub-link-block">
    <p>
      For broader market context, see the
      <a href="https://supplementsingapore.neoi.jp/">Supplements Singapore guide</a>.
    </p>
  </div>

  <script type="application/ld+json" set:html={webPageJsonLd}></script>
  <script type="application/ld+json" set:html={breadcrumbJsonLd}></script>
</BaseLayout>
