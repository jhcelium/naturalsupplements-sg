---
import site from "../../data/site.json";
import { canonicalUrl, siteOrigin } from "../lib/canonical";

interface Props {
  title?: string;
  description?: string;
  path?: string;
  image?: string;
}
const { title, description, path, image } = Astro.props;

const fullTitle = title ? `${title} | ${site.siteName}` : site.siteName;
const canonical = canonicalUrl(path);
const desc = description ?? "";
const ogDesc = desc.trim() ? desc : fullTitle;
const ogImageAbs = `${siteOrigin()}${image ?? "/logo.png"}`;
---
<title>{fullTitle}</title>
<meta name="robots" content="index,follow" />
{desc && <meta name="description" content={desc} />}
<link rel="canonical" href={canonical} />
<link rel="alternate" hreflang="x-default" href={canonical} />
<link rel="alternate" hreflang="en-SG" href={canonical} />
<link rel="alternate" hreflang="en" href={canonical} />

<meta property="og:type" content="website" />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={ogDesc} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImageAbs} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:locale" content="en_SG" />
<meta property="og:site_name" content={site.siteName} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={ogDesc} />
<meta name="twitter:image" content={ogImageAbs} />
